NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_REVALIDATE_SECONDS=3600

# Gate 11 — Auth (Credentials MVP)
# Generate per-env with: openssl rand -hex 32
NEXTAUTH_SECRET=
# Public URL the frontend is reachable at. Localhost in dev, https://malagasyfishes.org in prod.
NEXTAUTH_URL=http://localhost:3000
# Master kill-switch for the auth UI. Default false until staging soak completes.
# When false, /login, /signup, /verify, /account direct URLs still resolve but
# nav links are hidden — useful for UAT before flipping the visible flag.
NEXT_PUBLIC_FEATURE_AUTH=false

# Gate 12 — ORCID (post-ABQ stretch). Leave blank until Gate 12.
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
