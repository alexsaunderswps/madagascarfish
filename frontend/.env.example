NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_REVALIDATE_SECONDS=3600

# Gate 11 — Auth (Credentials MVP)
# Generate per-env with: openssl rand -hex 32
NEXTAUTH_SECRET=
# Public URL the frontend is reachable at. Localhost in dev, https://malagasyfishes.org in prod.
NEXTAUTH_URL=http://localhost:3000
# Master kill-switch for the auth UI. Default false until staging soak completes.
# When false, /login, /signup, /verify, /account direct URLs still resolve but
# nav links are hidden — useful for UAT before flipping the visible flag.
NEXT_PUBLIC_FEATURE_AUTH=false

# Gate 12 — ORCID (post-ABQ stretch). Leave blank until Gate 12.
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# Gate L1 — i18n. Master flag for the locale switcher and /fr|/de|/es
# route prefixes. When false, the site behaves as English-only and
# /fr/... etc. return 404. Flip true once L2 ships translated UI strings.
NEXT_PUBLIC_FEATURE_I18N=false

# Per-locale flags. Each gates whether that locale's prefix is accepted
# by middleware and whether it appears in the <LocaleSwitcher /> dropdown.
# Default false until that locale's content review (gates L2-L6) is human-
# approved. Sequence: flip _FR true after L4 ships, _DE after L5, _ES after L6.
NEXT_PUBLIC_FEATURE_I18N_FR=false
NEXT_PUBLIC_FEATURE_I18N_DE=false
NEXT_PUBLIC_FEATURE_I18N_ES=false
