# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostGIS)
DATABASE_URL=postgis://postgres:postgres@db:5432/mffcp

# Redis (cache + Celery broker)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# IUCN Red List API (required for Gate 06)
IUCN_API_TOKEN=

# MinIO / S3 (dev only)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=mffcp-media
AWS_S3_ENDPOINT_URL=http://minio:9000

# Gate L1+ — i18n. DeepL API key for machine-translation pipeline (used
# starting in Gate L3). Free tier keys end in ":fx"; paid tier keys do not.
# Get one at https://www.deepl.com/pro-api. Leave blank until L3 — L1 makes
# no MT calls.
DEEPL_API_KEY=
