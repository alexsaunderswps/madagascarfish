#: accounts/models.py:56
msgid "1=Public, 2=Researcher, 3=Coordinator, 4=Program Manager, 5=Admin"
msgstr "1=Öffentlich, 2=Forscher, 3=Koordinator, 4=Programmmanager, 5=Administrator"

#: accounts/models.py:68
msgid "Inactive until manually activated or email-verified."
msgstr "Inaktiv, bis es manuell aktiviert oder per E-Mail bestätigt wurde."

#: accounts/models.py:77
msgid ""
"Preferred locale for transactional emails and (when logged in) the default "
"UI locale on first visit. User-changeable from the account page."
msgstr "Bevorzugte Spracheinstellung für Transaktions-E-Mails und (bei angemeldeten Benutzern) die Standard-Spracheinstellung der Benutzeroberfläche beim ersten Besuch. Kann vom Benutzer auf der Kontoseite geändert werden."

#: accounts/serializers.py:17
msgid "An account with this email already exists."
msgstr "Ein Konto mit dieser E-Mail-Adresse ist bereits vorhanden."

#: accounts/templates/accounts/verify_email_body.html:4
#: accounts/templates/accounts/verify_email_subject.txt:1
msgid "Verify your Madagascar Fish account"
msgstr "Bestätige dein Madagascar Fish-Konto"

#: accounts/templates/accounts/verify_email_body.html:6
msgid "Click to verify your account — link expires in 48 hours."
msgstr "Klicken Sie hier, um Ihr Konto zu bestätigen – der Link ist 48 Stunden lang gültig."

#: accounts/templates/accounts/verify_email_body.html:10
#, python-format
msgid "Welcome to %(platform_short_name)s"
msgstr "Willkommen bei %(platform_short_name)s"

#: accounts/templates/accounts/verify_email_body.html:14
#: accounts/templates/accounts/verify_email_body.txt:3
msgid ""
"To finish creating your account, click the verification link below. The link "
"is valid for 48 hours."
msgstr "Um die Einrichtung Ihres Kontos abzuschließen, klicken Sie bitte auf den unten stehenden Bestätigungslink. Der Link ist 48 Stunden lang gültig."

#: accounts/templates/accounts/verify_email_body.html:21
msgid "Verify my account"
msgstr "Mein Konto bestätigen"

#: accounts/templates/accounts/verify_email_body.html:28
msgid "If the button doesn't work, copy and paste this URL into your browser:"
msgstr "Falls die Schaltfläche nicht funktioniert, kopieren Sie diese URL und fügen Sie sie in Ihren Browser ein:"

#: accounts/templates/accounts/verify_email_body.html:35
msgid "If you didn't sign up for an account, you can safely ignore this email."
msgstr "Falls Sie sich nicht für ein Konto registriert haben, können Sie diese E-Mail getrost ignorieren."

#: accounts/templates/accounts/verify_email_body.txt:1
msgid "Welcome to the Malagasy Freshwater Fishes Conservation Platform."
msgstr "Willkommen bei der Plattform zum Schutz der Süßwasserfische Madagaskars."

#: accounts/templates/accounts/verify_email_body.txt:7
msgid "If you didn't sign up for an account, you can ignore this email."
msgstr "Wenn Sie sich nicht für ein Konto registriert haben, können Sie diese E-Mail ignorieren."

#: accounts/views.py:118
msgid "Registration successful. Check your email to verify your account."
msgstr "Die Registrierung war erfolgreich. Bitte überprüfe deine E-Mails, um dein Konto zu bestätigen."

#: accounts/views.py:129
msgid "Missing verification token."
msgstr "Das Bestätigungs-Token fehlt."

#: accounts/views.py:137
msgid "Verification link has expired."
msgstr "Der Bestätigungslink ist abgelaufen."

#: accounts/views.py:142 accounts/views.py:150
msgid "Invalid verification token."
msgstr "Ungültiges Verifizierungstoken."

#: accounts/views.py:155
msgid "Account already verified."
msgstr "Das Konto wurde bereits verifiziert."

#: accounts/views.py:160
msgid "Account verified successfully."
msgstr "Das Konto wurde erfolgreich verifiziert."

#: accounts/views.py:170
msgid "Too many login attempts. Try again in 15 minutes."
msgstr "Zu viele Anmeldeversuche. Bitte versuche es in 15 Minuten erneut."

#: accounts/views.py:184
msgid "Invalid email or password."
msgstr "Ungültige E-Mail-Adresse oder ungültiges Passwort."

#: accounts/views.py:203
msgid "Logged out successfully."
msgstr "Sie wurden erfolgreich abgemeldet."

#: husbandry/admin.py:182
msgid "Review is overdue; public page will show a 'review pending' note."
msgstr "Die Überprüfung ist überfällig; auf der öffentlichen Seite wird der Hinweis „Überprüfung ausstehend“ angezeigt."

#: husbandry/admin.py:203
msgid "last_reviewed_by is required to publish."
msgstr "„last_reviewed_by“ ist für die Veröffentlichung erforderlich."

#: husbandry/admin.py:205
msgid "last_reviewed_at is required to publish."
msgstr "„last_reviewed_at“ ist für die Veröffentlichung erforderlich."

#: husbandry/admin.py:207
msgid "At least one source citation is required to publish."
msgstr "Für eine Veröffentlichung ist mindestens eine Quellenangabe erforderlich."

#: husbandry/apps.py:8
msgid "Husbandry & Breeding Guidance"
msgstr "Leitfaden zur Haltung und Zucht"

#: husbandry/models.py:55
msgid ""
"Gates public API + frontend teaser. Draft records are invisible to the "
"public."
msgstr "Gates öffentliche API + Frontend-Teaser. Entwürfe sind für die Öffentlichkeit nicht sichtbar."

#: husbandry/models.py:129
msgid "Free text at MVP. Structured contributor records are post-MVP (BA §5)."
msgstr "Freitext bei MVP. Strukturierte Mitwirkenden-Datensätze erfolgen nach MVP (BA §5)."

#: husbandry/models.py:137 husbandry/models.py:140
msgid "Required when published=True."
msgstr "Erforderlich, wenn published=True."

#: husbandry/models.py:148
msgid "Species husbandry record"
msgstr "Art-Haltungsnachweis"

#: husbandry/models.py:149
msgid "Species husbandry records"
msgstr "Aufzeichnungen zur Tierhaltung"

#: husbandry/models.py:182
msgid "A reviewer is required to publish a husbandry record."
msgstr "Ein Gutachter ist verpflichtet, ein Haltungsprotokoll zu veröffentlichen."

#: husbandry/models.py:186
msgid "A review date is required to publish a husbandry record."
msgstr "Für die Veröffentlichung eines Tierhaltungsprotokolls ist ein Überprüfungstermin erforderlich."

#: i18n/admin.py:50
msgid "English source"
msgstr "Englische Quelle"

#: i18n/admin.py:68
msgid ""
"The English source text. Read-only — edit on the underlying Species or Taxon "
"admin form if the source needs to change."
msgstr "Der englische Quelltext. Nur-Lese-Zugriff – nehmen Sie Änderungen im zugehörigen Verwaltungsformular für Arten oder Taxa vor, falls der Quelltext geändert werden muss."

#: i18n/admin.py:73
msgid "Target translation"
msgstr "Zielübersetzung"

#: i18n/admin.py:89
msgid ""
"The translation in the target locale. Saving this form writes the edit back "
"to the underlying object's &lt;field&gt;_&lt;locale&gt; column. Substantive "
"edits should be paired with a 'Send back to mt_draft' to re-route through "
"review."
msgstr "Die Übersetzung in der Zielsprache. Durch das Speichern dieses Formulars wird die Änderung in die Spalte &lt;field&gt;_&lt;locale&gt; des zugrunde liegenden Objekts geschrieben. Wesentliche Änderungen sollten mit einem „Zurück an mt_draft senden“ einhergehen, damit sie erneut zur Überprüfung weitergeleitet werden."

#: i18n/admin.py:140
msgid "Identity"
msgstr "Identität"

#: i18n/admin.py:152
msgid "Side-by-side comparison + inline edit"
msgstr "Seite-an-Seite-Vergleich + Bearbeitung direkt im Text"

#: i18n/admin.py:156
msgid ""
"Edit the translation directly here; saving writes it back to the underlying "
"object. The English source is read-only."
msgstr "Bearbeiten Sie die Übersetzung direkt hier; beim Speichern wird sie wieder in das zugrunde liegende Objekt geschrieben. Der englische Quelltext ist schreibgeschützt."

#: i18n/admin.py:163
msgid "Pipeline state"
msgstr "Pipeline-Status"

#: i18n/admin.py:177
msgid "Audit"
msgstr "Prüfung"

#: i18n/admin.py:216
#, python-brace-format
msgid ""
"Translation content for {model}#{id}.{field} ({locale}) saved. If the change "
"is substantive, consider 'Send back to mt_draft' so it routes through review "
"again."
msgstr "Der Übersetzungsinhalt für {model}#{id}.{field} ({locale}) wurde gespeichert. Wenn es sich um eine wesentliche Änderung handelt, sollten Sie die Option „Zurück an mt_draft senden“ in Betracht ziehen, damit der Text erneut geprüft wird."

#: i18n/admin.py:242
msgid "(no admin URL)"
msgstr "(keine Admin-URL)"

#: i18n/admin.py:247
#, python-brace-format
msgid ""
"Open underlying {model} admin (opens new tab) — for editing the English "
"source or using all-locale tabs →"
msgstr ""
"Zugriff auf den Admin-Bereich des zugrunde liegenden {model} (öffnet einen "
"neuen Tab) – zum Bearbeiten des englischen Quelltextes oder zur Nutzung der "
"Registerkarten für alle Sprachversionen →"

#: i18n/admin.py:252
msgid "Underlying admin"
msgstr "Zuständige Verwaltungsstelle"

#: i18n/admin.py:276
#, python-brace-format
msgid "{n} row(s) advanced to writer_reviewed."
msgstr "{n} Zeile(n) wurden in den Status „writer_reviewed“ verschoben."

#: i18n/admin.py:281
#, python-brace-format
msgid "{n} row(s) skipped (not in mt_draft state)."
msgstr "{n} Zeile(n) übersprungen (nicht im Status „mt_draft“)."

#: i18n/admin.py:285
msgid "Advance: mt_draft → writer_reviewed"
msgstr "Status: mt_draft → writer_reviewed"

#: i18n/admin.py:307
#, python-brace-format
msgid "{n} row(s) approved (writer_reviewed → human_approved)."
msgstr "{n} Zeile(n) genehmigt (vom Verfasser geprüft → von einem Mitarbeiter genehmigt)."

#: i18n/admin.py:314
#, python-brace-format
msgid ""
"{n} row(s) skipped (not in writer_reviewed state — advance through writer "
"review first)."
msgstr "{n} Zeile(n) übersprungen (befinden sich nicht im Status „writer_reviewed“ – bitte führen Sie zunächst die Überprüfung durch den Verfasser durch)."

#: i18n/admin.py:320
msgid "Approve: writer_reviewed → human_approved"
msgstr "Genehmigen: writer_reviewed → human_approved"

#: i18n/admin.py:339
#, python-brace-format
msgid ""
"{n} row(s) sent back to mt_draft. The translation content itself is "
"unchanged; only the pipeline status was reset."
msgstr "{n} Zeile(n) wurden an mt_draft zurückgesendet. Der Übersetzungsinhalt selbst bleibt unverändert; lediglich der Pipeline-Status wurde zurückgesetzt."

#: i18n/admin.py:347
#, python-brace-format
msgid "{n} row(s) skipped (already in mt_draft state)."
msgstr "{n} Zeile(n) übersprungen (befinden sich bereits im Status „mt_draft“)."

#: i18n/admin.py:353
msgid "Send back to mt_draft"
msgstr "Zurück an mt_draft senden"

#: i18n/apps.py:18
msgid "Translation pipeline"
msgstr "Übersetzungsprozess"

#: i18n/models.py:73
msgid "Provider that produced the original draft (e.g., 'deepl', 'manual')."
msgstr "Anbieter, der den ursprünglichen Entwurf erstellt hat (z. B. „deepl“, „manual“)."

#: i18n/templates/email/base.html:52
#, python-format
msgid "You're receiving this because you signed up at %(platform)s."
msgstr "Sie erhalten diese Nachricht, weil Sie sich bei %(platform)s angemeldet haben."

#: populations/admin.py:127
msgid "You can only modify records for your own institution."
msgstr "Sie können nur Datensätze Ihrer eigenen Einrichtung bearbeiten."

#: populations/admin.py:132
msgid "You can only create records for your own institution."
msgstr "Sie können nur Datensätze für Ihre eigene Einrichtung anlegen."

#: populations/models.py:35
msgid "Visible at Tier 3+ only"
msgstr "Nur ab Stufe 3 sichtbar"

#: populations/models.py:130
msgid "Institution holding the studbook / coordination responsibility."
msgstr "Zuchtbuchführende Stelle / Koordinierungsstelle."

#: populations/models.py:138
msgid "The named studbook keeper, if one is assigned."
msgstr "Der benannte Zuchtbuchführer, sofern einer benannt wurde."

#: populations/models.py:144
msgid ""
"Institutions that have joined the program (not including the coordinator)."
msgstr "Einrichtungen, die sich dem Programm angeschlossen haben (ohne den Koordinator)."

#: populations/models.py:149
msgid "Optional demographic target per the program's plan."
msgstr "Optionale Zielgruppe gemäß dem Programmplan."

#: populations/models.py:153
msgid "Short human summary of the current plan. Full plan docs link out."
msgstr "Kurze Zusammenfassung des aktuellen Plans. Link zu den vollständigen Planungsunterlagen."

#: populations/models.py:157
msgid "External link to the authoritative plan (PDF, Confluence, etc.)."
msgstr "Externer Link zum offiziellen Plan (PDF, Confluence usw.)."

#: populations/models.py:210
msgid "Date the transfer was first proposed / logged."
msgstr "Datum, an dem die Übertragung erstmals vorgeschlagen bzw. erfasst wurde."

#: populations/models.py:216
msgid "Date the transfer actually completed. Required when status='completed'."
msgstr "Datum, an dem die Überweisung tatsächlich abgeschlossen wurde. Erforderlich, wenn status='completed' ist."

#: populations/models.py:235
msgid "Optional: the program this transfer serves."
msgstr "Optional: die Sendung, für die diese Übertragung bestimmt ist."

#: populations/models.py:336
msgid "The program this recommendation was issued under, if any."
msgstr "Das Programm, im Rahmen dessen diese Empfehlung ausgesprochen wurde, falls vorhanden."

#: populations/models.py:371
msgid "When the recommendation was issued. Required."
msgstr "Wann die Empfehlung ausgesprochen wurde. Erforderlich."

#: populations/models.py:376
msgid "Target date for action, if the plan specifies one."
msgstr "Zieltermin für die Maßnahme, sofern im Plan angegeben"

#: populations/models.py:380
msgid "Free text — what happened. Filled in at resolution."
msgstr "Freitext – Was ist passiert? Bei der Beschlussfassung ausgefüllt."

#: populations/models.py:447
msgid "Signed change in male count. Negative = loss."
msgstr "Vorzeichenbehaftete Veränderung der Anzahl der Männer. Negativ = Rückgang."

#: species/admin.py:58
#, python-format
msgid "`%(field)s` is required when source is `manual_expert`."
msgstr "`%(field)s` ist erforderlich, wenn die Quelle `manual_expert` ist."

#: species/admin.py:64
msgid "`reason` is required when creating a manual_expert assessment."
msgstr "Bei der Erstellung einer „manual_expert“-Bewertung ist die Angabe eines „reason“ erforderlich."

#: species/admin.py:341
msgid "No audit entries recorded."
msgstr "Es wurden keine Prüfprotokolle erfasst."

#: species/admin.py:432
msgid ""
"Tier 3 (Conservation Coordinator) or higher is required to author a "
"manual_expert assessment."
msgstr "Für die Erstellung eines Handbuchs zur Expertenbewertung ist die Stufe 3 (Naturschutzkoordinator) oder höher erforderlich."

#: species/admin.py:520
msgid "Required only when resolution='reconciled'."
msgstr "Nur erforderlich, wenn resolution='reconciled' ist."

#: species/admin_revalidate.py:42
msgid ""
"Revalidate is not configured: set NEXT_REVALIDATE_URL and "
"NEXT_REVALIDATE_SECRET in the environment."
msgstr "Die Revalidierung ist nicht konfiguriert: Legen Sie NEXT_REVALIDATE_URL und NEXT_REVALIDATE_SECRET in der Umgebung fest."

#: species/admin_revalidate.py:56
#, python-format
msgid "Revalidate timed out after %(t)ss — check frontend health."
msgstr ""
"Die Revalidierung ist nach %(t)ss abgelaufen – bitte überprüfen Sie den "
"Zustand des Frontends."

#: species/admin_revalidate.py:59
#, python-format
msgid "Revalidate request failed: %(e)s"
msgstr "Die erneute Validierung der Anfrage ist fehlgeschlagen: %(e)s"

#: species/admin_revalidate.py:63
#, python-format
msgid "Revalidate returned HTTP %(code)s: %(body)s"
msgstr "Revalidierung lieferte HTTP %(code)s: %(body)s"

#: species/admin_revalidate.py:71
#, python-format
msgid "Revalidate succeeded (HTTP %(code)s, non-JSON body)."
msgstr "Die erneute Validierung war erfolgreich (HTTP %(code)s, Nicht-JSON-Body)."

#: species/admin_revalidate.py:77
#, python-format
msgid "Revalidated %(n)s path(s)."
msgstr "%(n)s Pfade wurden revalidiert."

#: species/admin_revalidate.py:80
#, python-format
msgid "%(n)s path(s) failed: %(list)s"
msgstr "%(n)s Pfade sind fehlgeschlagen: %(list)s"

#: species/admin_revalidate.py:85
msgid "Revalidate public pages (clear Next.js cache)"
msgstr "Öffentliche Seiten neu laden (Next.js-Cache leeren)"

#: species/models.py:309
msgid "Fixed slot consumed by a specific page region."
msgstr "Fester Platz, der von einem bestimmten Seitenbereich belegt wird."

#: species/models.py:314
msgid "PNG or JPEG at or above the expected dimensions. Empty = no asset yet."
msgstr "PNG oder JPEG mit mindestens den erwarteten Abmessungen. Leer = noch kein Bildmaterial."

#: species/models.py:319
msgid "Screen-reader description of the thumbnail. Required when image is set."
msgstr "Beschreibung der Miniaturansicht für Screenreader. Erforderlich, wenn ein Bild festgelegt ist."

#: species/models.py:324
msgid "Attribution line shown alongside the image, if any."
msgstr "Gegebenenfalls wird neben dem Bild eine Quellenangabe angezeigt."

#: species/models.py:327
msgid "Target render width in CSS pixels. Set when the slot is introduced."
msgstr "Zielbreite in CSS-Pixeln. Wird beim Einfügen des Slots festgelegt."

#: species/models.py:330
msgid "Target render height in CSS pixels. Set when the slot is introduced."
msgstr "Zielhöhe der Darstellung in CSS-Pixeln. Wird beim Einfügen des Slots festgelegt."

#: species/models.py:334
msgid ""
"Internal notes for editors — where the asset renders, sourcing guidance."
msgstr "Interne Hinweise für Redakteure – wo das Bildmaterial angezeigt wird, Hinweise zur Quellenangabe."

