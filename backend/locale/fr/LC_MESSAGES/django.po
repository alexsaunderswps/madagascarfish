#: accounts/models.py:56
msgid "1=Public, 2=Researcher, 3=Coordinator, 4=Program Manager, 5=Admin"
msgstr ""
"1=Public, 2=Chercheur, 3=Coordinateur, 4=Responsable de programme, "
"5=Administrateur"

#: accounts/models.py:68
msgid "Inactive until manually activated or email-verified."
msgstr "Inactif jusqu'à activation manuelle ou vérification de l'e-mail."

#: accounts/models.py:77
msgid ""
"Preferred locale for transactional emails and (when logged in) the default "
"UI locale on first visit. User-changeable from the account page."
msgstr ""
"Langue préférée pour les e-mails transactionnels et (lorsque vous êtes "
"connecté) la langue par défaut de l'interface lors de la première visite. "
"Modifiable depuis la page de compte."

#: accounts/serializers.py:17
msgid "An account with this email already exists."
msgstr "Un compte avec cette adresse e-mail existe déjà."

#: accounts/templates/accounts/verify_email_body.html:4
#: accounts/templates/accounts/verify_email_subject.txt:1
msgid "Verify your Madagascar Fish account"
msgstr "Vérifiez votre compte Madagascar Fish"

#: accounts/templates/accounts/verify_email_body.html:6
msgid "Click to verify your account — link expires in 48 hours."
msgstr "Cliquez pour vérifier votre compte — le lien expire dans 48 heures."

#: accounts/templates/accounts/verify_email_body.html:10
#, python-format
msgid "Welcome to %(platform_short_name)s"
msgstr "Bienvenue sur %(platform_short_name)s"

#: accounts/templates/accounts/verify_email_body.html:14
#: accounts/templates/accounts/verify_email_body.txt:3
msgid ""
"To finish creating your account, click the verification link below. The link "
"is valid for 48 hours."
msgstr ""
"Pour finaliser la création de votre compte, cliquez sur le lien de "
"vérification ci-dessous. Le lien est valable 48 heures."

#: accounts/templates/accounts/verify_email_body.html:21
msgid "Verify my account"
msgstr "Vérifier mon compte"

#: accounts/templates/accounts/verify_email_body.html:28
msgid "If the button doesn't work, copy and paste this URL into your browser:"
msgstr "Si le bouton ne fonctionne pas, copiez et collez cette URL dans votre navigateur :"

#: accounts/templates/accounts/verify_email_body.html:35
msgid "If you didn't sign up for an account, you can safely ignore this email."
msgstr "Si vous n'avez pas créé de compte, vous pouvez ignorer cet e-mail en toute sécurité."

#: accounts/templates/accounts/verify_email_body.txt:1
msgid "Welcome to the Malagasy Freshwater Fishes Conservation Platform."
msgstr "Bienvenue sur la plateforme de conservation des poissons d'eau douce de Madagascar."

#: accounts/templates/accounts/verify_email_body.txt:7
msgid "If you didn't sign up for an account, you can ignore this email."
msgstr "Si vous n'avez pas créé de compte, vous pouvez ignorer cet e-mail."

#: accounts/views.py:118
msgid "Registration successful. Check your email to verify your account."
msgstr ""
"Inscription réussie. Consultez votre messagerie pour vérifier votre compte."

#: accounts/views.py:129
msgid "Missing verification token."
msgstr "Jeton de vérification manquant."

#: accounts/views.py:137
msgid "Verification link has expired."
msgstr "Le lien de vérification a expiré."

#: accounts/views.py:142 accounts/views.py:150
msgid "Invalid verification token."
msgstr "Jeton de vérification invalide."

#: accounts/views.py:155
msgid "Account already verified."
msgstr "Compte déjà vérifié."

#: accounts/views.py:160
msgid "Account verified successfully."
msgstr "Compte vérifié avec succès."

#: accounts/views.py:170
msgid "Too many login attempts. Try again in 15 minutes."
msgstr "Trop de tentatives de connexion. Réessayez dans 15 minutes."

#: accounts/views.py:184
msgid "Invalid email or password."
msgstr "E-mail ou mot de passe incorrect."

#: accounts/views.py:203
msgid "Logged out successfully."
msgstr "Déconnexion réussie."

#: husbandry/admin.py:182
msgid "Review is overdue; public page will show a 'review pending' note."
msgstr ""
"La relecture est en retard ; la page publique affichera une note « relecture "
"en attente »."

#: husbandry/admin.py:203
msgid "last_reviewed_by is required to publish."
msgstr "« last_reviewed_by » est requis pour publier."

#: husbandry/admin.py:205
msgid "last_reviewed_at is required to publish."
msgstr "« last_reviewed_at » est requis pour publier."

#: husbandry/admin.py:207
msgid "At least one source citation is required to publish."
msgstr "Au moins une citation de source est requise pour publier."

#: husbandry/apps.py:8
msgid "Husbandry & Breeding Guidance"
msgstr "Élevage et reproduction"

#: husbandry/models.py:55
msgid ""
"Gates public API + frontend teaser. Draft records are invisible to the "
"public."
msgstr ""
"Conditionne l'accès à l'API publique et au teaser front-end. Les "
"enregistrements en brouillon sont invisibles pour le public."

#: husbandry/models.py:129
msgid "Free text at MVP. Structured contributor records are post-MVP (BA §5)."
msgstr ""
"Texte libre au stade MVP. Les enregistrements de contributeurs structurés "
"sont post-MVP (BA §5)."

#: husbandry/models.py:137 husbandry/models.py:140
msgid "Required when published=True."
msgstr "Requis lorsque published=True."

#: husbandry/models.py:148
msgid "Species husbandry record"
msgstr "Fiche d'élevage d'espèce"

#: husbandry/models.py:149
msgid "Species husbandry records"
msgstr "Fiches d'élevage d'espèces"

#: husbandry/models.py:182
msgid "A reviewer is required to publish a husbandry record."
msgstr "Un relecteur est requis pour publier une fiche d'élevage."

#: husbandry/models.py:186
msgid "A review date is required to publish a husbandry record."
msgstr "Une date de relecture est requise pour publier une fiche d'élevage."

#: i18n/admin.py:50
msgid "English source"
msgstr "Source anglaise"

#: i18n/admin.py:68
msgid ""
"The English source text. Read-only — edit on the underlying Species or Taxon "
"admin form if the source needs to change."
msgstr ""
"Texte source en anglais. Lecture seule — modifiez-le sur le formulaire "
"d'administration Species ou Taxon sous-jacent si la source doit changer."

#: i18n/admin.py:73
msgid "Target translation"
msgstr "Traduction cible"

#: i18n/admin.py:89
msgid ""
"The translation in the target locale. Saving this form writes the edit back "
"to the underlying object's &lt;field&gt;_&lt;locale&gt; column. Substantive "
"edits should be paired with a 'Send back to mt_draft' to re-route through "
"review."
msgstr ""
"La traduction dans la langue cible. L'enregistrement de ce formulaire "
"réécrit la modification dans la colonne &lt;field&gt;_&lt;locale&gt; de "
"l'objet sous-jacent. Les modifications substantielles doivent être "
"accompagnées d'un « Renvoyer en mt_draft » pour repasser par la relecture."

#: i18n/admin.py:140
msgid "Identity"
msgstr "Identité"

#: i18n/admin.py:152
msgid "Side-by-side comparison + inline edit"
msgstr "Comparaison côte à côte + édition en ligne"

#: i18n/admin.py:156
msgid ""
"Edit the translation directly here; saving writes it back to the underlying "
"object. The English source is read-only."
msgstr ""
"Modifiez la traduction directement ici ; l'enregistrement la réécrit dans "
"l'objet sous-jacent. La source anglaise est en lecture seule."

#: i18n/admin.py:163
msgid "Pipeline state"
msgstr "État du pipeline"

#: i18n/admin.py:177
msgid "Audit"
msgstr "Audit"

#: i18n/admin.py:216
#, python-brace-format
msgid ""
"Translation content for {model}#{id}.{field} ({locale}) saved. If the change "
"is substantive, consider 'Send back to mt_draft' so it routes through review "
"again."
msgstr ""
"Contenu de traduction pour {model}#{id}.{field} ({locale}) enregistré. Si la "
"modification est substantielle, envisagez « Renvoyer en mt_draft » pour "
"repasser par la relecture."

#: i18n/admin.py:242
msgid "(no admin URL)"
msgstr "(aucune URL d'administration)"

#: i18n/admin.py:247
#, python-brace-format
msgid ""
"Open underlying {model} admin (opens new tab) — for editing the English "
"source or using all-locale tabs →"
msgstr ""
"Ouvrir l'administration {model} sous-jacente (nouvel onglet) — pour modifier "
"la source anglaise ou utiliser les onglets multi-langues →"

#: i18n/admin.py:252
msgid "Underlying admin"
msgstr "Administration sous-jacente"

#: i18n/admin.py:276
#, python-brace-format
msgid "{n} row(s) advanced to writer_reviewed."
msgstr "{n} ligne(s) passée(s) en writer_reviewed."

#: i18n/admin.py:281
#, python-brace-format
msgid "{n} row(s) skipped (not in mt_draft state)."
msgstr "{n} ligne(s) ignorée(s) (pas en état mt_draft)."

#: i18n/admin.py:285
msgid "Advance: mt_draft → writer_reviewed"
msgstr "Avancer : mt_draft → writer_reviewed"

#: i18n/admin.py:307
#, python-brace-format
msgid "{n} row(s) approved (writer_reviewed → human_approved)."
msgstr "{n} ligne(s) approuvée(s) (writer_reviewed → human_approved)."

#: i18n/admin.py:314
#, python-brace-format
msgid ""
"{n} row(s) skipped (not in writer_reviewed state — advance through writer "
"review first)."
msgstr ""
"{n} ligne(s) ignorée(s) (pas en état writer_reviewed — passez d'abord par la "
"relecture)."

#: i18n/admin.py:320
msgid "Approve: writer_reviewed → human_approved"
msgstr "Approuver : writer_reviewed → human_approved"

#: i18n/admin.py:339
#, python-brace-format
msgid ""
"{n} row(s) sent back to mt_draft. The translation content itself is "
"unchanged; only the pipeline status was reset."
msgstr ""
"{n} ligne(s) renvoyée(s) en mt_draft. Le contenu de la traduction reste "
"inchangé ; seul l'état du pipeline a été réinitialisé."

#: i18n/admin.py:347
#, python-brace-format
msgid "{n} row(s) skipped (already in mt_draft state)."
msgstr "{n} ligne(s) ignorée(s) (déjà en état mt_draft)."

#: i18n/admin.py:353
msgid "Send back to mt_draft"
msgstr "Renvoyer en mt_draft"

#: i18n/apps.py:18
msgid "Translation pipeline"
msgstr "Pipeline de traduction"

#: i18n/models.py:73
msgid "Provider that produced the original draft (e.g., 'deepl', 'manual')."
msgstr ""
"Fournisseur ayant produit le brouillon original (par exemple « deepl », "
"« manual »)."

#: i18n/templates/email/base.html:52
#, python-format
msgid "You're receiving this because you signed up at %(platform)s."
msgstr "Vous recevez ce message parce que vous vous êtes inscrit sur %(platform)s."

#: populations/admin.py:127
msgid "You can only modify records for your own institution."
msgstr ""
"Vous ne pouvez modifier que les enregistrements de votre propre institution."

#: populations/admin.py:132
msgid "You can only create records for your own institution."
msgstr ""
"Vous ne pouvez créer des enregistrements que pour votre propre institution."

#: populations/models.py:35
msgid "Visible at Tier 3+ only"
msgstr "Visible uniquement au niveau d'accès 3 et plus"

#: populations/models.py:130
msgid "Institution holding the studbook / coordination responsibility."
msgstr "Institution responsable du livre généalogique et de la coordination."

#: populations/models.py:138
msgid "The named studbook keeper, if one is assigned."
msgstr "Le gardien du livre généalogique nommé, le cas échéant."

#: populations/models.py:144
msgid ""
"Institutions that have joined the program (not including the coordinator)."
msgstr ""
"Institutions ayant rejoint le programme (hors institution coordinatrice)."

#: populations/models.py:149
msgid "Optional demographic target per the program's plan."
msgstr "Objectif démographique facultatif selon le plan du programme."

#: populations/models.py:153
msgid "Short human summary of the current plan. Full plan docs link out."
msgstr ""
"Résumé court du plan actuel. Les documents complets sont accessibles via "
"lien externe."

#: populations/models.py:157
msgid "External link to the authoritative plan (PDF, Confluence, etc.)."
msgstr "Lien externe vers le plan de référence (PDF, Confluence, etc.)."

#: populations/models.py:210
msgid "Date the transfer was first proposed / logged."
msgstr ""
"Date à laquelle le transfert a été proposé ou enregistré pour la première "
"fois."

#: populations/models.py:216
msgid "Date the transfer actually completed. Required when status='completed'."
msgstr ""
"Date à laquelle le transfert a effectivement été achevé. Requis lorsque "
"status=« completed »."

#: populations/models.py:235
msgid "Optional: the program this transfer serves."
msgstr "Facultatif : le programme auquel ce transfert se rapporte."

#: populations/models.py:336
msgid "The program this recommendation was issued under, if any."
msgstr ""
"Le programme dans le cadre duquel cette recommandation a été émise, le cas "
"échéant."

#: populations/models.py:371
msgid "When the recommendation was issued. Required."
msgstr "Date d'émission de la recommandation. Requis."

#: populations/models.py:376
msgid "Target date for action, if the plan specifies one."
msgstr "Date cible d'action, si le plan en précise une."

#: populations/models.py:380
msgid "Free text — what happened. Filled in at resolution."
msgstr "Texte libre — ce qui s'est passé. À renseigner à la résolution."

#: populations/models.py:447
msgid "Signed change in male count. Negative = loss."
msgstr "Variation signée du nombre de mâles. Négatif = perte."

#: species/admin.py:58
#, python-format
msgid "`%(field)s` is required when source is `manual_expert`."
msgstr "« %(field)s » est requis lorsque la source est « manual_expert »."

#: species/admin.py:64
msgid "`reason` is required when creating a manual_expert assessment."
msgstr ""
"« reason » est requis lors de la création d'une évaluation manual_expert."

#: species/admin.py:341
msgid "No audit entries recorded."
msgstr "Aucune entrée d'audit enregistrée."

#: species/admin.py:432
msgid ""
"Tier 3 (Conservation Coordinator) or higher is required to author a "
"manual_expert assessment."
msgstr ""
"Le niveau d'accès 3 (Coordinateur de conservation) ou supérieur est requis "
"pour créer une évaluation manual_expert."

#: species/admin.py:520
msgid "Required only when resolution='reconciled'."
msgstr "Requis uniquement lorsque resolution=« reconciled »."

#: species/admin_revalidate.py:42
msgid ""
"Revalidate is not configured: set NEXT_REVALIDATE_URL and "
"NEXT_REVALIDATE_SECRET in the environment."
msgstr ""
"La revalidation n'est pas configurée : définissez NEXT_REVALIDATE_URL et "
"NEXT_REVALIDATE_SECRET dans l'environnement."

#: species/admin_revalidate.py:56
#, python-format
msgid "Revalidate timed out after %(t)ss — check frontend health."
msgstr ""
"La revalidation a expiré après %(t)ss — vérifiez la santé du front-end."

#: species/admin_revalidate.py:59
#, python-format
msgid "Revalidate request failed: %(e)s"
msgstr "La requête de revalidation a échoué : %(e)s"

#: species/admin_revalidate.py:63
#, python-format
msgid "Revalidate returned HTTP %(code)s: %(body)s"
msgstr "La revalidation a renvoyé HTTP %(code)s : %(body)s"

#: species/admin_revalidate.py:71
#, python-format
msgid "Revalidate succeeded (HTTP %(code)s, non-JSON body)."
msgstr "Revalidation réussie (HTTP %(code)s, corps non-JSON)."

#: species/admin_revalidate.py:77
#, python-format
msgid "Revalidated %(n)s path(s)."
msgstr "%(n)s chemin(s) revalidé(s)."

#: species/admin_revalidate.py:80
#, python-format
msgid "%(n)s path(s) failed: %(list)s"
msgstr "%(n)s chemin(s) en échec : %(list)s"

#: species/admin_revalidate.py:85
msgid "Revalidate public pages (clear Next.js cache)"
msgstr "Revalider les pages publiques (vider le cache Next.js)"

#: species/models.py:309
msgid "Fixed slot consumed by a specific page region."
msgstr "Emplacement fixe occupé par une région de page spécifique."

#: species/models.py:314
msgid "PNG or JPEG at or above the expected dimensions. Empty = no asset yet."
msgstr ""
"PNG ou JPEG à des dimensions au moins égales aux dimensions attendues. Vide "
"= aucun visuel pour l'instant."

#: species/models.py:319
msgid "Screen-reader description of the thumbnail. Required when image is set."
msgstr ""
"Description pour lecteur d'écran de la vignette. Requis lorsqu'une image est "
"définie."

#: species/models.py:324
msgid "Attribution line shown alongside the image, if any."
msgstr "Ligne d'attribution affichée à côté de l'image, le cas échéant."

#: species/models.py:327
msgid "Target render width in CSS pixels. Set when the slot is introduced."
msgstr ""
"Largeur de rendu cible en pixels CSS. Renseignée lors de l'introduction de "
"l'emplacement."

#: species/models.py:330
msgid "Target render height in CSS pixels. Set when the slot is introduced."
msgstr ""
"Hauteur de rendu cible en pixels CSS. Renseignée lors de l'introduction de "
"l'emplacement."

#: species/models.py:334
msgid ""
"Internal notes for editors — where the asset renders, sourcing guidance."
msgstr ""
"Notes internes pour les éditeurs — où le visuel s'affiche, indications de "
"sourçage."

#: species/models.py:349
msgid "ISO 639-1 code: en, fr, mg"
msgstr "Code ISO 639-1 : en, fr, mg"
