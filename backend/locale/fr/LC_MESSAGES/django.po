# French translation catalog for the Madagascar Freshwater Fish
# Conservation Platform. Source-of-truth file; .mo is built at image-build
# time. Voice/glossary follows .claude/agents/conservation-writer.md.
#
msgid ""
msgstr ""
"Project-Id-Version: madagascarfish 1.0\n"
