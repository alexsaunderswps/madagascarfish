# Hetzner staging — copy to deploy/staging/.env on the server and fill in.
# Do NOT commit the populated file. .env is gitignored.

# --- Postgres (used by the db service) ---
POSTGRES_DB=mffcp
POSTGRES_USER=mffcp
POSTGRES_PASSWORD=__GENERATE_STRONG_PASSWORD__

# --- Caddy ---
CADDY_DOMAIN=api.malagasyfishes.org

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=__GENERATE_WITH_django_secrets__
DJANGO_ALLOWED_HOSTS=api.malagasyfishes.org
# Caddy terminates TLS and forwards HTTP to Django; disable SSL redirect inside the container.
DJANGO_SECURE_SSL_REDIRECT=False
# Hetzner has Caddy in front of Django on a private docker network; the WSGI
# port is not publicly reachable. Trust X-Forwarded-For so /auth/login/
# rate-limiting sees the real client IP instead of Caddy's container IP.
# REQUIRED for the rate limiter to function correctly behind the proxy.
TRUST_X_FORWARDED_FOR=True

# --- Database / Redis URLs (point at the sibling compose services) ---
DATABASE_URL=postgis://mffcp:__GENERATE_STRONG_PASSWORD__@db:5432/mffcp
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- CORS (frontend surfaces) ---
CORS_ALLOWED_ORIGINS=https://malagasyfishes.org,https://www.malagasyfishes.org,https://madagascarfish.vercel.app

# --- Integrations ---
IUCN_API_TOKEN=

# --- Frontend base URL (for verification emails, password-reset links, etc.) ---
FRONTEND_BASE_URL=https://malagasyfishes.org

# --- Next.js cache revalidation webhook (OPERATIONS.md §11.1) ---
# URL must point at the canonical (non-www) public hostname.
# Secret must match Vercel's REVALIDATE_SECRET exactly. Blank disables the webhook.
NEXT_REVALIDATE_URL=https://malagasyfishes.org/api/revalidate
NEXT_REVALIDATE_SECRET=__MATCH_VERCEL_REVALIDATE_SECRET__
NEXT_REVALIDATE_TIMEOUT_SECONDS=10

# --- Coordinator dashboard service token (OPERATIONS.md §11.2) ---
# Must match the COORDINATOR_API_TOKEN value in Vercel env. Blank disables the
# Bearer-token bypass — only real Tier 3+ sessions can hit the endpoints.
COORDINATOR_API_TOKEN=__MATCH_VERCEL_COORDINATOR_API_TOKEN__

# --- Email (Resend SMTP — Alex-ToDo §1.4) ---
# DEFAULT_FROM_EMAIL must use a domain you've verified (DKIM + SPF) in Resend.
# EMAIL_HOST_USER is the literal string `resend`; the API key goes in EMAIL_HOST_PASSWORD.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=__RESEND_API_KEY__
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@malagasyfishes.org
