# Hetzner staging — copy to deploy/staging/.env on the server and fill in.
# Do NOT commit the populated file. .env is gitignored.

# --- Postgres (used by the db service) ---
POSTGRES_DB=mffcp
POSTGRES_USER=mffcp
POSTGRES_PASSWORD=__GENERATE_STRONG_PASSWORD__

# --- Caddy ---
CADDY_DOMAIN=api.malagasyfishes.org

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=__GENERATE_WITH_django_secrets__
DJANGO_ALLOWED_HOSTS=api.malagasyfishes.org
# Caddy terminates TLS and forwards HTTP to Django; disable SSL redirect inside the container.
DJANGO_SECURE_SSL_REDIRECT=False

# --- Database / Redis URLs (point at the sibling compose services) ---
DATABASE_URL=postgis://mffcp:__GENERATE_STRONG_PASSWORD__@db:5432/mffcp
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- CORS (frontend surfaces) ---
CORS_ALLOWED_ORIGINS=https://malagasyfishes.org,https://www.malagasyfishes.org,https://madagascarfish.vercel.app

# --- Integrations ---
IUCN_API_TOKEN=

# --- Frontend base URL (for emails, callbacks later) ---
FRONTEND_BASE_URL=https://malagasyfishes.org
